# Copy this file to .env and fill in your API keys.
# Only ONE key is needed. The pipeline checks in this order: Groq → OpenAI → Gemini.
# Without any key, a local fallback generator is used (lower quality answers).

# --- RECOMMENDED (Free, Fast, Llama 3.3 70B) ---
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# --- ALTERNATIVE: OpenAI (Paid) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- ALTERNATIVE: Google Gemini (Free tier available) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
